# Copy this file to ".env" and fill in your details so the form can send email.
#
# The example below uses Gmail. For Gmail you must create an "App Password"
# (Google Account -> Security -> 2-Step Verification -> App passwords) and
# use that 16-character code as SMTP_PASS — your normal password won't work.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASS=your-app-password

# Who the date details get sent to (defaults to Trisha if omitted)
TO_EMAIL=Trisha@trishafeydesigns.com

# Optional: what appears in the "From" field (defaults to SMTP_USER)
FROM_EMAIL=your-address@gmail.com

# Optional: port for the local server
PORT=3000
